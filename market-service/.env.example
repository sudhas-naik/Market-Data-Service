# Application
APP_NAME=market-service
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# PostgreSQL (use port 5433 when connecting to Docker Compose Postgres from your host)
DATABASE_URL=postgresql+asyncpg://market:market@localhost:5433/market_db

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_QUOTE_TTL_SECONDS=10

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=market-service
KAFKA_TOPIC_QUOTE_UPDATED=market.quote.updated
KAFKA_TOPIC_TICK=market.tick
KAFKA_TOPIC_CANDLE_COMPLETED=market.candle.completed
KAFKA_TOPIC_NEWS=market.news

# Market Provider
MARKET_PROVIDER=mock

# Workers
QUOTE_REFRESH_INTERVAL_SECONDS=1
NEWS_FETCH_INTERVAL_SECONDS=300
